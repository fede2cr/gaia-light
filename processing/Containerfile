# ── Build stage ─────────────────────────────────────────────────────
FROM debian:trixie AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates \
    pkg-config libssl-dev \
    gcc libc6-dev \
    && rm -rf /var/lib/apt/lists/*

ENV RUSTUP_HOME=/usr/local/rustup CARGO_HOME=/usr/local/cargo
ENV PATH="/usr/local/cargo/bin:$PATH"
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable

WORKDIR /build

# Copy workspace manifests first for dependency caching
COPY Cargo.toml Cargo.lock ./
COPY common/Cargo.toml common/Cargo.toml
COPY capture/Cargo.toml capture/Cargo.toml
COPY processing/Cargo.toml processing/Cargo.toml
COPY web/Cargo.toml web/Cargo.toml
COPY video-import/Cargo.toml video-import/Cargo.toml

# Create dummy sources so cargo can fetch/compile dependencies
RUN mkdir -p common/src capture/src processing/src web/src video-import/src && \
    echo "pub fn _dummy() {}" > common/src/lib.rs && \
    echo "fn main() {}" > capture/src/main.rs && \
    echo "fn main() {}" > processing/src/main.rs && \
    echo "pub fn _dummy() {}" > web/src/lib.rs && \
    echo "fn main() {}" > web/src/main.rs && \
    echo "fn main() {}" > video-import/src/main.rs && \
    cargo build --release -p gaia-light-processing 2>/dev/null || true

# Copy real source (touch to invalidate cargo fingerprint from dummy layer)
COPY common/src common/src
COPY processing/src processing/src
RUN touch common/src/lib.rs processing/src/main.rs

# Build for real
RUN cargo build --release -p gaia-light-processing

# ── Model converter stage ──────────────────────────────────────────
# Export MegaDetector v5a to ONNX via torch.hub + yolov5 and download
# SpeciesNet.  The ONNX files are baked into the final image so the
# processing container works immediately without network access.
FROM python:3.11-slim AS converter

# git is needed by torch.hub to clone the ultralytics/yolov5 repo,
# which provides the models.yolo module required to deserialize the
# MegaDetector v5a checkpoint.
RUN apt-get update && apt-get install -y --no-install-recommends \
        git cmake build-essential libgl1 libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir \
       torch torchvision --index-url https://download.pytorch.org/whl/cpu \
    && pip install --no-cache-dir \
       numpy opencv-python-headless pandas requests pyyaml scipy seaborn \
       ipython tqdm matplotlib psutil \
       onnx onnxruntime onnxsim onnxscript timm onnx2torch \
       lightning omegaconf PytorchWildlife \
       Cython gdown \
    && pip install --no-cache-dir \
       git+https://github.com/KaiyangZhou/deep-person-reid.git

WORKDIR /export

COPY processing/scripts/export_models.py .
RUN python export_models.py /export/models

# ── Runtime stage ──────────────────────────────────────────────────
FROM debian:trixie-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates ffmpeg \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/target/release/gaia-light-processing /usr/local/bin/gaia-light-processing

# Bake converted models into the image so they can be seeded on first start
COPY --from=converter /export/models/ /usr/local/share/gaia/models/

# ── Smoke-test: verify the ONNX models load correctly in tract ─────
# This fails the build if the exported model is incompatible, catching
# issues before the image is shipped.
RUN gaia-light-processing --check-models /usr/local/share/gaia/models

RUN mkdir -p /etc/gaia /data /models

# Default config -- override by mounting your own
RUN echo '# Gaia Light Processing config\n\
LATITUDE=-1\n\
LONGITUDE=-1\n\
CONFIDENCE=0.5\n\
MODEL_DIR=/models\n\
DB_PATH=/data/detections.db\n\
CAPTURE_SERVER_URL=http://capture:8090\n\
POLL_INTERVAL_SECS=5\n\
RECS_DIR=/data\n' > /etc/gaia/gaia-light.conf

VOLUME ["/data", "/models"]

ENTRYPOINT ["gaia-light-processing"]
CMD ["/etc/gaia/gaia-light.conf"]
