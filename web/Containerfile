# ── Build stage ─────────────────────────────────────────────────────
FROM debian:trixie AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates \
    pkg-config libssl-dev \
    gcc libc6-dev \
    perl make \
    && rm -rf /var/lib/apt/lists/*

# Install rustup (needed for wasm32 target, not available via Debian packages)
ENV RUSTUP_HOME=/usr/local/rustup CARGO_HOME=/usr/local/cargo
ENV PATH="/usr/local/cargo/bin:$PATH"
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable

WORKDIR /build

# Install wasm target + cargo-leptos
RUN rustup target add wasm32-unknown-unknown && \
    cargo install cargo-leptos

# Copy workspace manifests first for dependency caching
COPY Cargo.toml Cargo.lock ./
COPY common/Cargo.toml common/Cargo.toml
COPY capture/Cargo.toml capture/Cargo.toml
COPY processing/Cargo.toml processing/Cargo.toml
COPY web/Cargo.toml web/Cargo.toml
COPY video-import/Cargo.toml video-import/Cargo.toml

# Create dummy sources so cargo can fetch/compile dependencies
RUN mkdir -p common/src capture/src processing/src web/src video-import/src && \
    echo "pub fn _dummy() {}" > common/src/lib.rs && \
    echo "fn main() {}" > capture/src/main.rs && \
    echo "fn main() {}" > processing/src/main.rs && \
    echo "pub fn _dummy() {}" > web/src/lib.rs && \
    echo "fn main() {}" > web/src/main.rs && \
    echo "fn main() {}" > video-import/src/main.rs && \
    cargo build --release -p gaia-light-web --features ssr 2>/dev/null || true

# Copy real source + assets (touch to invalidate cargo fingerprint from dummy layer)
COPY common/src common/src
COPY web/src web/src
RUN touch common/src/lib.rs web/src/lib.rs web/src/main.rs
# Copy style and public dirs if they exist
COPY web/styl[e] web/style
COPY web/publi[c] web/public

# Build with cargo-leptos (compiles SSR binary + WASM hydration bundle)
# Install matching wasm-bindgen-cli from source so cargo-leptos never needs to
# download a prebuilt binary (no prebuilt binaries exist for arm64).
ENV LEPTOS_WASM_OPT_VERSION=version_127
RUN WB_VERSION=$(grep -A1 'name = "wasm-bindgen"' Cargo.lock | grep version | head -1 | sed 's/.*"\(.*\)"/\1/') \
    && cargo install wasm-bindgen-cli --version "$WB_VERSION" \
    && cd web && cargo leptos build --release

# ── Runtime stage ──────────────────────────────────────────────────
FROM debian:trixie-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Copy the server binary
COPY --from=builder /build/target/release/gaia-light-web /usr/local/bin/gaia-light-web

# Copy the built site (WASM bundle, CSS, static assets)
COPY --from=builder /build/target/site /srv/site

RUN mkdir -p /data

# Leptos reads LEPTOS_SITE_ROOT at runtime for serving static assets
ENV LEPTOS_SITE_ROOT=/srv/site
ENV LEPTOS_SITE_ADDR=0.0.0.0:8190
ENV GAIA_DB_PATH=/data/detections.db

EXPOSE 8190

VOLUME ["/data"]

ENTRYPOINT ["gaia-light-web"]
